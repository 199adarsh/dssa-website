        "weight": "bold",
        "lineHeight": "1.2",
        "characteristics": "Section headers, clean and prominent"
      },
      "body": {
        "size": "16-18px",
        "weight": "normal",
        "lineHeight": "1.5-1.6",
        "characteristics": "Regular content, readable and accessible"
      },
      "caption": {
        "size": "14-16px",
        "weight": "normal",
        "color": "secondary",
        "characteristics": "Supporting text, labels, and metadata"
      }
    },
    "fontFamily": "Modern sans-serif (likely system fonts or web-safe alternatives)",
    "characteristics": [
      "Clean, minimal typography",
      "Strong hierarchy through size and weight",
      "Generous whitespace",
      "High contrast for readability"
    ]
  },

