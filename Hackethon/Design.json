{
  "designSystem": {
    "name": "Modern Tech Platform Design System",
    "version": "1.0",
    "description": "A contemporary design system for tech platforms featuring clean typography, gradient accents, and structured content layouts"
  },
  
  "colorPalette": {
    "primary": {
      "background": "#FFFFFF",
      "text": "#000000",
      "textSecondary": "#666666"
    },
    "accent": {
      "gradient": "linear-gradient(135deg, #FFB6C1, #87CEEB, #98FB98)",
      "gradientAlt": "Soft pastel gradient with pink, blue, and green tones"
